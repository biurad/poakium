       echo \PHP_EOL.'Poakium CLI '.(new \DateTimeImmutable('now'))->format('Y-m-d H:i:s').\PHP_EOL;
       echo \PHP_EOL.'Available commands:'.\PHP_EOL;
       echo '  reinstall                    =  Uninstalls and reinstalls composer dependencies for /packages/*/'.\PHP_EOL;
       echo '  purge                        =  Removes all installed composer dependencies from /packages/*/'.\PHP_EOL;
       echo '  package <repo@folder:remote> =  Adds a subtree of an independent repo into /packages/*/'.\PHP_EOL;
}
