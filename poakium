       echo '  install              =  Installs the dependencies from composer.json to /packages/*/' . \PHP_EOL;
       echo '  reinstall            =  Uninstalls and reinstalls composer dependencies to /packages/*/' . \PHP_EOL;
       echo '  purge                =  Removes all installed composer dependencies from /packages/*/' . \PHP_EOL;
       echo '  package              =  Adds a subtree of an independent repo into /packages/*/' . \PHP_EOL;
}
