if (!\file_exists($autoload = __DIR__.'/vendor/autoload.php') && \function_exists('shell_exec')) {
    $path = \shell_exec('composer -v') ? 'composer' : ''; // check for global composer command

    // fallback to download composer.phar
    if (!$path || !\preg_match('/(composer|composer\.phar)$/', $path)) {
        \shell_exec('curl -s https://getcomposer.org/installer | php');
        $path = 'php composer.phar';
    }

    echo 'Preparing to install vendor dependencies...'.\PHP_EOL.\PHP_EOL;
    echo \shell_exec($path.'  install --no-interaction --prefer-dist --optimize-autoloader');
    echo \PHP_EOL.\PHP_EOL;
}

require $autoload;

[$execute, $processName, $command, $args] = (static function () {
    $arguments = $_SERVER['argv'];
    $execute = static function (string $command, array $args = [], string $cwd = null, array $env = null, callable $callback = null) {
        $process = new Symfony\Component\Process\Process([$command, ...$args], $cwd, $env);
        echo \PHP_EOL;

        return $process->run(fn (string $type, string $data) => $callback ? $callback($type, $data) : print($data));
    };

    return [$execute, \array_shift($arguments), \array_shift($arguments), $arguments];
})();

switch ($command) {
    case 'reinstall':
        $execute('php', ['./poakium', 'purge']) | $execute('php', ['./poakium']);
    break;
    case 'purge':
        if (0 !== $execute('rm', ['-rf', 'vendor/', 'packages/*/vendor/', 'packages/*/composer.lock'])) {
            foreach (\glob('./{vendor/,composer.lock,packages/*/{vendor/,composer.lock}}', \GLOB_BRACE) as $pPath) {
                Nette\Utils\FileSystem::delete(__DIR__.\substr($pPath, 1));
            }
        }
        echo 'Vendor dependencies purged successfully'.\PHP_EOL;
    break;
    case 'package':
        if (empty($args)) {
            foreach (\json_decode(\file_get_contents(__DIR__.'/.gitrepo'), true) as $k => $v) {
                if (!\is_string($v)) {
                    $g = ($v['host'] ?? 'https://github.com')."/{$k}.git@".$v['folder'];
                    $args[] = $g.(isset($v['remote']) ? ':'.$v['remote'] : '');

                    continue;
                }
                $args[] = "https://github.com/{$k}.git@{$v}";
            }
        }

        foreach ($args as $package) {
            [$repo, $folder] = \explode('@', $package, 2);
            [$folder, $remote] = \str_contains($folder, ':') ? \explode(':', $folder, 2) : [$folder, null];

            $execute('git', ['status', '--porcelain'], callback: static function (string $type, string $data): void {
                if (!empty($data)) {
                    echo \PHP_EOL.'Git working directory is dirty, commit or stash changes before creating a new branch.'.\PHP_EOL;
                    exit(1);
                }
            });

            echo 'Fetching '.$folder.\PHP_EOL;
            $execute(
                'git',
                ['config', '--get', 'remote.'.($r = $remote ?? $folder).'.fetch'],
                callback: static function (string $type, string $data) use ($r, $repo, $execute): void {
                    if (empty($data)) {
                        echo 'Remote '.$r.' not found, creating...'.\PHP_EOL;
                        $execute('git', ['remote', 'add', $r, $repo]); // add remote repo
                        $execute('git', ['config', '--add', "remote.{$r}.fetch", "refs/tags/*:refs/tags/{$r}/*"]);
                        $execute('git', ['config', "remote.{$r}.tagOpt", '--no-tags']);
                    }
                }
            );
            $execute('git', ['fetch', '--atomic', $r]); // fetch remote repo
            $execute(
                'git',
                ['branch', '-r', '-l', "{$r}/*", '--no-color', '--format', '%(refname:lstrip=3)'],
                callback: function (string $type, string $data) use ($r, $repo, $folder, $execute): void {
                    foreach (\explode("\n", $data, -1) as $branch) {
                        echo 'Switching and cleaning branch '.($b = $r.'-'.$branch).\PHP_EOL;
                        $execute('git', ['symbolic-ref', 'HEAD', 'refs/heads/'.\trim($b)]); // switch to branch
                        $execute('git', ['clean', '-f', '-d', '-x']); // clean up
                        $execute('git', ['rm', '-rfq', '--ignore-unmatch', '.']); // Extra to ensure everything is removed
                        $execute('git', ['reset']);

                        echo "Merging commits from {$folder}/{$branch}".' to "'.$b.'" branch'.\PHP_EOL;
                        $execute('git', ['merge', '--no-commit', '-s', 'ours', "{$r}/{$branch}", '--allow-unrelated-histories']);
                        \mkdir($gitFolder = 'packages/'.$folder, recursive: true); // create folder if not exists

                        foreach (\glob('{*,.*}', \GLOB_BRACE) as $gitFile) {
                            if (\in_array($gitFile, ['.', '..', '.git', 'packages'], true)) {
                                continue;
                            }
                            $execute('git', ['mv', '-f', $gitFile, $gitFolder.'/']); // move files to packages folder
                        }
                        $execute('git', ['add', '-A']); // add all files to index
                        $execute('git', ['commit', '-m', 'Merge '.\substr($repo, 0, -4)."/{$branch}", '--allow-empty']); // commit changes
                        $execute('git', ['merge', 'main', '--allow-unrelated-histories']); // rebase from main branch
                    }
                }
            );
        }
        $execute('git', ['checkout', '.']);
        echo \PHP_EOL.'Succeeded! You can now push your branch to your remote repository.'.\PHP_EOL;
    break;
    default:
       echo <<<'EOT'

‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚Ėą‚ēó
